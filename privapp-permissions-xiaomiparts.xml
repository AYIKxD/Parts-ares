<?xml version="1.0" encoding="utf-8"?>
<!--
    Privileged-app permission allowlist for XiaomiParts.

    Any permission declared in AndroidManifest.xml that is protectionLevel="privileged"
    (or "signature|privileged") must be explicitly listed here, otherwise the PackageManager
    will deny it at install time even though the app is placed in /system_ext/priv-app.
-->
<permissions>
    <privapp-permissions package="org.lineageos.xiaomiparts">
        <!-- Hardware lights API (used by LedUtils for RGB LED control) -->
        <permission name="android.permission.CONTROL_DEVICE_LIGHTS" />
        <!-- Inject synthetic key/touch events (used by Action.triggerVirtualKeypress) -->
        <permission name="android.permission.INJECT_EVENTS" />
        <!-- Write global Settings.System / Settings.Secure values -->
        <permission name="android.permission.WRITE_SETTINGS" />
        <permission name="android.permission.WRITE_SECURE_SETTINGS" />
        <!-- Wake/sleep the device (used by ACTION_POWER and ACTION_WAKE_DEVICE) -->
        <permission name="android.permission.DEVICE_POWER" />
        <!-- Force-stop / kill background processes (used by ACTION_KILL) -->
        <permission name="android.permission.FORCE_STOP_PACKAGES" />
        <permission name="android.permission.KILL_BACKGROUND_PROCESSES" />
        <!-- Status bar expand/collapse (used by ACTION_NOTIFICATIONS) -->
        <permission name="android.permission.STATUS_BAR" />
        <!-- Required for reading wallpaper colors (used by Material You dynamic theming) -->
        <permission name="android.permission.READ_WALLPAPER_INTERNAL" />
    </privapp-permissions>
</permissions>
