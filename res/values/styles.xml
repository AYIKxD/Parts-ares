<resources>

    <!--
        Theme for XiaomiParts activities.
        Inherits Theme.DeviceDefault.Settings — the same base theme used by the Settings app.
        This gives us Material You system colors, standard preference styling, and correct
        system action bar without any extra dependencies.
    -->
    <style name="XiaomiPartsSettingsTheme" parent="@android:style/Theme.DeviceDefault.Settings">
        <item name="android:windowActionBar">true</item>
        <item name="android:windowNoTitle">false</item>
    </style>

</resources>
