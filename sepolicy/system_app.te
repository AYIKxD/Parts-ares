# SEPolicy rules for XiaomiParts (system_app)
#
# XiaomiParts runs with android:sharedUserId="android.uid.system" so it runs
# in the system_app domain. Grant access to device-specific hardware nodes.

# Allow system_app to read from /dev/gamekey (trigger buttons and sliders)
# Using vendor_gamekey_device type which is now defined in our tree
allow system_app vendor_gamekey_device:chr_file { open read getattr };

# Allow XiaomiParts to control the RGB LEDs (for disco mode)
allow system_app vendor_sysfs_aw2013_leds:dir search;
allow system_app vendor_sysfs_aw2013_leds:file { open read write getattr };
