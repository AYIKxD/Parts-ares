<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    package="org.lineageos.xiaomiparts"
    android:sharedUserId="android.uid.system">

    <uses-sdk android:minSdkVersion="31" android:targetSdkVersion="36" />

    <!-- Permissions -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WRITE_SETTINGS" />
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" />
    <uses-permission android:name="android.permission.DEVICE_POWER" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INJECT_EVENTS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />
    <uses-permission android:name="android.permission.FORCE_STOP_PACKAGES" />
    <uses-permission android:name="android.permission.STATUS_BAR" />
    <uses-permission android:name="android.permission.READ_WALLPAPER_INTERNAL" />

    <application
        android:label="@string/XiaomiParts"
        android:icon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault.NoActionBar">

        <!-- Main Compose Activity -->
        <activity
            android:name=".ui.XiaomiPartsActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
            </intent-filter>
        </activity>

        <!-- Settings Dashboard Integration (appears in Settings app) -->
        <activity-alias
            android:name=".XiaomiPartsSettingsAlias"
            android:exported="true"
            android:label="@string/XiaomiParts"
            android:targetActivity=".ui.XiaomiPartsActivity">
            <intent-filter>
                <action android:name="com.android.settings.action.IA_SETTINGS" />
            </intent-filter>
            <meta-data
                android:name="com.android.settings.category"
                android:value="com.android.settings.category.ia.homepage" />
            <meta-data
                android:name="com.android.settings.summary"
                android:resource="@string/XiaomiParts_summary" />
            <meta-data
                android:name="com.android.settings.icon"
                android:resource="@drawable/ic_settings_gestures" />
            <meta-data
                android:name="com.android.settings.icon_tintable"
                android:value="true" />
        </activity-alias>

        <!-- Boot Receiver -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Key Handler (system service) -->
        <activity
            android:name=".KeyHandler"
            android:exported="false" />

        <!-- Gamekey Service (trigger detection) -->
        <service
            android:name=".gamekey.GamekeyService"
            android:exported="false" />

        <!-- Task Service (foreground LED/game monitoring) -->
        <service
            android:name=".TaskService"
            android:exported="false" />

        <!-- LED On Call Receiver -->
        <receiver
            android:name=".led.LedOnCall"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!-- QS Tiles -->
        <service
            android:name=".triggers.TriggerMapTile"
            android:exported="true"
            android:icon="@drawable/ic_qs_trigger_map"
            android:label="@string/qs_trigger_map_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".led.LedDiscoTile"
            android:exported="true"
            android:icon="@drawable/ic_qs_led_disco"
            android:label="@string/qs_led_disco_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Legacy Activities (still used by Java services internally) -->
        <activity
            android:name=".gestures.TouchGesturesActivity"
            android:exported="false" />

        <activity
            android:name=".triggers.CustomTriggerActivity"
            android:exported="false" />

        <activity
            android:name=".util.AppListActivity"
            android:exported="false" />

    </application>
</manifest>
