android_app {
    name: "XiaomiParts",

    static_libs: [
        // AndroidX core
        "androidx.core_core-ktx",
        "androidx.appcompat_appcompat",

        // Compose UI
        "androidx.activity_activity-compose",
        "androidx.compose.animation_animation-core",
        "androidx.compose.animation_animation-graphics",
        "androidx.compose.foundation_foundation",
        "androidx.compose.material3_material3",
        "androidx.compose.material3_material3-window-size-class",
        "androidx.compose.material_material-icons-core",
        "androidx.compose.material_material-icons-extended",
        "androidx.compose.runtime_runtime",
        "androidx.compose.ui_ui",

        // Navigation
        "androidx.navigation_navigation-compose",

        // Lifecycle
        "androidx.lifecycle_lifecycle-viewmodel-compose",
        "androidx.lifecycle_lifecycle-runtime-compose",

        // Material Design
        "com.google.android.material_material",

        // Preferences (still used by legacy services)
        "androidx.preference_preference",

        // Kotlin
        "kotlin-parcelize-runtime",
        "kotlinx-coroutines-android",
        "kotlinx-coroutines-core",

        // System
        "SystemUISharedLib",
    ],

    srcs: [
        "src/**/*.kt",
    ],

    certificate: "platform",
    system_ext_specific: true,
    privileged: true,

    resource_dirs: ["res"],

    optimize: {
        enabled: true,
    },
    dex_preopt: {
        enabled: false,
    },
    platform_apis: true,

    min_sdk_version: "36",
    target_sdk_version: "36",

    kotlincflags: [
        "-Xjvm-default=all",
        "-opt-in=kotlin.RequiresOptIn",
        "-P plugin:androidx.compose.compiler.plugins.kotlin:sourceInformation=true",
    ],

    kotlin_plugins: ["kotlin-parcelize-compiler-plugin"],

    required: [
        "privapp-permissions-xiaomiparts.xml",
        "init.xiaomiparts.rc",
    ],
}

prebuilt_etc {
    name: "privapp-permissions-xiaomiparts.xml",
    src: "privapp-permissions-xiaomiparts.xml",
    sub_dir: "permissions",
    system_ext_specific: true,
}

prebuilt_etc {
    name: "init.xiaomiparts.rc",
    src: "init.xiaomiparts.rc",
    sub_dir: "init",
    system_ext_specific: true,
}
